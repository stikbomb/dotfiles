#!/usr/bin/env python3
"""Fuzzel bookmark picker for Vivaldi."""

import json
import subprocess
import sys
from pathlib import Path

BOOKMARKS = Path.home() / ".config/vivaldi/Default/Bookmarks"


def collect(node, items):
    if node.get("type") == "url":
        name = node["name"].strip() or node["url"]
        items.append((name, node["url"]))
    for child in node.get("children", []):
        collect(child, items)


def main():
    # prevent multiple instances from key repeat
    if subprocess.run(["pgrep", "-x", "fuzzel"], capture_output=True).returncode == 0:
        sys.exit(0)

    data = json.loads(BOOKMARKS.read_text())
    items = []
    for root in data["roots"].values():
        collect(root, items)

    # deduplicate by url, preserve order
    seen = set()
    unique = []
    for name, url in items:
        if url not in seen:
            seen.add(url)
            unique.append((name, url))

    lines = "\n".join(f"{name}\t{url}" for name, url in unique)

    result = subprocess.run(
        ["fuzzel", "--dmenu", "--prompt", "bookmark: "],
        input=lines,
        capture_output=True,
        text=True,
    )

    if result.returncode != 0 or not result.stdout.strip():
        sys.exit(0)

    selected = result.stdout.strip()
    # extract url (after last tab)
    url = selected.rsplit("\t", 1)[-1] if "\t" in selected else selected

    subprocess.Popen(["xdg-open", url])


if __name__ == "__main__":
    main()
