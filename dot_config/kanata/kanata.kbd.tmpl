(defcfg
  process-unmapped-keys yes
  danger-enable-cmd yes
  linux-dev-names-include (
    {{ if eq .machine "desktop" -}}
    "Ergohaven K:03 PRO 43mm"
    {{- else if eq .machine "laptop" -}}
    "AT Translated Set 2 keyboard"
    {{- end }}
  )
)

(defsrc
  lmet f q{{ if eq .machine "laptop" }} spc{{ end }}
)

;; ──────────────────────────────────────────────
;; Aliases
;; ──────────────────────────────────────────────

(defalias
  ;; f: если alt зажат — сменить раскладку (если Alacritty) и отправить alt+f через wtype
  ;;    иначе — обычная f
  f (fork
      f
      (cmd sh -c "NIRI_SOCKET=$(ls /run/user/$(id -u)/niri.*.sock 2>/dev/null | head -1); export NIRI_SOCKET; niri msg focused-window 2>/dev/null | grep -qi alacritty && niri msg action switch-layout 0; wtype -M alt -k f")
      (lalt ralt)
    )

  ;; lmet: эмитить lmet нативно + активировать слой meta-held
  met (multi lmet (layer-while-held meta-held))

  ;; q в слое meta-held:
  ;;   - если Rambox: отправить ctrl+q через wtype
  ;;   - всегда: эмитить q нативно (lmet уже зажат на том же устройстве → compositor видит lmet+q)
  mq (multi
       (cmd sh -c "NIRI_SOCKET=$(ls /run/user/$(id -u)/niri.*.sock 2>/dev/null | head -1); export NIRI_SOCKET; niri msg focused-window 2>/dev/null | grep -qi rambox && wtype -M ctrl -k q")
       q
     )
{{- if eq .machine "laptop" }}
  ;; spc: тап — пробел, удержание — shift
  spc (tap-hold 200 200 spc lsft)
{{- end }}
)

;; ──────────────────────────────────────────────
;; Layers
;; ──────────────────────────────────────────────

(deflayer base
  @met @f q{{ if eq .machine "laptop" }} @spc{{ end }}
)

(deflayer meta-held
  lmet @f @mq{{ if eq .machine "laptop" }} @spc{{ end }}
)
